# Required ─────────────────────────────────────────────────────────────
# Anthropic API key with Managed Agents access. Get one at
# https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-...

# Populated by `npm run setup-agent` ───────────────────────────────────
# The setup script provisions a template agent + environment + memory
# store on the Managed Agents platform and writes the resulting IDs back
# here. Run `npm run setup-agent` once after cloning; thereafter, re-run
# to bump the template version after editing scripts/agent.yml.
AGENT_ID=
ENV_ID=
MEMORY_STORE_ID=

# Optional ─────────────────────────────────────────────────────────────
# Model overrides. Defaults: brain = claude-opus-4-7 (the cartographer),
# pill agents + label batcher = claude-haiku-4-5-20251001.
# MAIN_MODEL=claude-opus-4-7
# MIST_MODEL=claude-haiku-4-5-20251001

# Express port. Vite proxies /api and /ws to this. Default: 4000.
# PORT=4000

# Autonomous wake (off by default). Set WAKE_INTERVAL_SEC to enable a
# cron loop that periodically wakes the cartographer on quiet canvases.
# 3600 = once an hour. The two filters keep noisy or stale projects out:
#   WAKE_MIN_QUIET_SEC — skip projects with activity in the last N
#                        seconds (default 300).
#   WAKE_MAX_AGE_HOURS — skip projects untouched for more than N hours
#                        (default 24).
# WAKE_INTERVAL_SEC=3600
# WAKE_MIN_QUIET_SEC=300
# WAKE_MAX_AGE_HOURS=24
